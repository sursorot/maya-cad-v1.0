{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.rl-core.tsbuildinfo",
    "baseUrl": "src",
    "paths": {
      "@maya/workspace-domain/*": ["../../../../apps/maya-web/src/domain/*"]
    }
  },
  "include": ["src"]
}

