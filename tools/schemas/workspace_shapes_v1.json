{
  "$id": "https://maya.build/contracts/workspace_shapes_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maya Workspace Shapes v1",
  "description": "Canonical shape definitions shared across all Maya contracts.",
  "oneOf": [
    { "$ref": "#/$defs/wall" },
    { "$ref": "#/$defs/opening" },
    { "$ref": "#/$defs/room" },
    { "$ref": "#/$defs/zone" },
    { "$ref": "#/$defs/dimension" },
    { "$ref": "#/$defs/line" },
    { "$ref": "#/$defs/polyline" },
    { "$ref": "#/$defs/arc" },
    { "$ref": "#/$defs/curve" },
    { "$ref": "#/$defs/rectangle" },
    { "$ref": "#/$defs/circle" },
    { "$ref": "#/$defs/guideline" },
    { "$ref": "#/$defs/text" }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "wall": {
      "type": "object",
      "required": ["id", "type", "start", "end", "thickness", "height"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "wall" },
        "start": { "$ref": "#/$defs/point" },
        "end": { "$ref": "#/$defs/point" },
        "thickness": { "type": "number", "minimum": 0.01 },
        "height": { "type": "number", "minimum": 0.1 },
        "controlPoint": {
          "oneOf": [
            { "$ref": "#/$defs/point" },
            { "type": "null" }
          ]
        },
        "alignment": {
          "type": "string",
          "enum": ["center", "inside", "outside"]
        }
      }
    },
    "opening": {
      "type": "object",
      "required": ["id", "type", "category", "center", "width", "height"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "opening" },
        "category": {
          "type": "string",
          "enum": ["door", "window", "skylight", "vent", "custom"]
        },
        "subtype": { "type": "string" },
        "center": { "$ref": "#/$defs/point" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "options": {
          "type": "object",
          "properties": {
            "hinge": { "enum": ["left", "right", "center"] },
            "swing": { "enum": ["in", "out", "both"] },
            "panelCount": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "parentWallId": { "$ref": "#/$defs/uuid" }
      }
    },
    "room": {
      "type": "object",
      "required": ["id", "type", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "room" },
        "points": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point" }
        },
        "label": { "type": "string" }
      }
    },
    "zone": {
      "type": "object",
      "required": ["id", "type", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "zone" },
        "points": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point" }
        },
        "category": { "type": "string" }
      }
    },
    "dimension": {
      "type": "object",
      "required": ["id", "type", "measurementType", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "dimension" },
        "measurementType": {
          "enum": ["linear", "arc", "span", "angle"]
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point" }
        },
        "value": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "line": {
      "type": "object",
      "required": ["id", "type", "start", "end"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "line" },
        "start": { "$ref": "#/$defs/point" },
        "end": { "$ref": "#/$defs/point" },
        "style": { "enum": ["solid", "dash", "dot"] }
      }
    },
    "polyline": {
      "type": "object",
      "required": ["id", "type", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "polyline" },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point" }
        }
      }
    },
    "arc": {
      "type": "object",
      "required": ["id", "type", "center", "radius", "startAngle", "endAngle"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "arc" },
        "center": { "$ref": "#/$defs/point" },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "startAngle": { "type": "number" },
        "endAngle": { "type": "number" }
      }
    },
    "curve": {
      "type": "object",
      "required": ["id", "type", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "curve" },
        "points": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point" }
        }
      }
    },
    "rectangle": {
      "type": "object",
      "required": ["id", "type", "origin", "width", "height"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "rectangle" },
        "origin": { "$ref": "#/$defs/point" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "rotation": { "type": "number" }
      }
    },
    "circle": {
      "type": "object",
      "required": ["id", "type", "center", "radius"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "circle" },
        "center": { "$ref": "#/$defs/point" },
        "radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "guideline": {
      "type": "object",
      "required": ["id", "type", "orientation", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "guideline" },
        "orientation": {
          "enum": ["horizontal", "vertical", "freeform"]
        },
        "position": { "$ref": "#/$defs/point" }
      }
    },
    "text": {
      "type": "object",
      "required": ["id", "type", "content", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "type": { "const": "text" },
        "content": { "type": "string" },
        "position": { "$ref": "#/$defs/point" },
        "alignment": {
          "enum": ["left", "center", "right"]
        }
      }
    }
  }
}

